# Firebase config — copy this file to ".env" and paste your project's values.
# Get them from: Firebase Console → Project settings → "Your apps" → Web app → SDK setup.
# Until these are filled in, the app runs in local-only mode (no login).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: comma-separated emails that get the baked-in Recomp workout plan.
# Leave blank so no personal addresses live in the source/bundle.
VITE_RECOMP_EMAILS=
