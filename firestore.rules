rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can read/write only their own state document, and writes are
    // validated: only the known slices, each of the expected type, with sane
    // list-size caps so a buggy/compromised client can't bloat or corrupt it.
    match /userState/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
             'profile', 'items', 'goals', 'habits',
             'journal', 'weight', 'water', 'clientUpdatedAt', 'updatedAt'
           ])
        && request.resource.data.profile is map
        && request.resource.data.items is list
        && request.resource.data.items.size() <= 5000
        && request.resource.data.goals is list
        && request.resource.data.goals.size() <= 1000
        && request.resource.data.habits is list
        && request.resource.data.habits.size() <= 500
        && request.resource.data.journal is list
        && request.resource.data.journal.size() <= 5000
        && request.resource.data.weight is list
        && request.resource.data.weight.size() <= 5000
        && request.resource.data.water is map;
    }
  }
}
